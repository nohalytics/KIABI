	partition Goal = m
		mode: import
		queryGroup: '02.Facts'
		source = ```
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject=P_Billing_Project]){[Name=P_Project_Name]}[Data], "
				   SELECT
				    Date,
				    ID_Store,
				    ID_Comparable_flag,
				    GMV_excl_VAT_local,
				    GMV_excl_VAT_euro
				FROM 
				    `expo_self_bi_sales.budget`
				WHERE 
				    Date >= DATE_TRUNC(
				        DATE_SUB(CURRENT_DATE(), INTERVAL 36 MONTH),
				        MONTH
				    )
				    AND Date <= CURRENT_DATE() - 1", null, [EnableFolding=true])
				in
				    Source
				```

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception

