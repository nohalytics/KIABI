	measure _Sales_level = ```
			not ISFILTERED('Product') 
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		isHidden
		displayFolder: 00.Construct
		lineageTag: 2db9bff2-b1c4-4daa-b9e3-da553bbae361

		changedProperty = IsHidden

	measure 'GMV excl. VAT' =
			
			IF (
			    [_IsLocal],
			    SWITCH (
			        TRUE (),
			        [_Sales_level], SUM ( 'Sales Class Level'[GMV_excl_VAT_local] ),
			        SUM ( Sales[GMV_excl_VAT_local] )
			    ),
			    SWITCH (
			        TRUE (),
			        [_Sales_level], SUM ( 'Sales Class Level'[GMV_excl_VAT_euro] ),
			        SUM ( Sales[GMV_excl_VAT_euro] )
