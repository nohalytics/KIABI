	measure 'Sales margin value' = [GMV excl. VAT] - [Sales PP excl. VAT]
		formatString: #,0.0
		displayFolder: 01.Sales\Y
		lineageTag: 142ddaa8-37ca-45d5-8823-66985d01d04b

	measure '_Sold quantities Y-1 (d)' =
			
			VAR ComparableStoresClass =
			    CALCULATETABLE ( VALUES ( 'Sales Class Level'[Id_Store] ) )
			VAR ComparableStoresProduct =
			    CALCULATETABLE ( VALUES ( 'Sales'[Id_Store] ) )
			VAR MaxDate =
			    MAX ( 'Calendar'[Date] )
			RETURN
			    SWITCH (
			        TRUE (),
			        [_Sales_level],
			            IF (
			                ISFILTERED ( 'Comparable Flag' ),
			                CALCULATE (
			                    [Sales quantities],
			                    TREATAS ( ComparableStoresClass, 'Sales Class Level'[ID_Store] ),
			                    SAMEPERIODLASTYEAR ( 'Calendar'[Date] ),
			                    'Calendar'[Date] <= EDATE ( MaxDate, -12 ),
			                    REMOVEFILTERS ( 'Comparable Flag' )
			                ),
			                CALCULATE (
			                    [Sales quantities],
			                    SAMEPERIODLASTYEAR ( 'Calendar'[Date] ),
			                    'Calendar'[Date] <= EDATE ( MaxDate, -12 )
			                )
			            ),
			        IF (
			            ISFILTERED ( 'Comparable Flag' ),
			            CALCULATE (
			                [Sales quantities],
			                TREATAS ( ComparableStoresProduct, 'Sales'[ID_Store] ),
			                SAMEPERIODLASTYEAR ( 'Calendar'[Date] ),
			                'Calendar'[Date] <= EDATE ( MaxDate, -12 ),
			                REMOVEFILTERS ( 'Comparable Flag' )
			            ),
			            CALCULATE (
			                [Sales quantities],
			                SAMEPERIODLASTYEAR ( 'Calendar'[Date] ),
			                'Calendar'[Date] <= EDATE ( MaxDate, -12 )
			            )
			        )
			    )
		formatString: #,0
		isHidden
		displayFolder: 01.Sales\Y-1\date to date
		lineageTag: c48f4bd8-81f3-4086-af6a-46a6ab90577e

