		sourceExpression = ```
			let
			Source = GoogleBigQuery.Database([ConnectionTimeout = #duration(0, 0, 5, 0), CommandTimeout=#duration(1, 0, 0, 0), BillingProject=P_Billing_Project]){[Name=P_Project_Name]}[Data],
			Query = Value.NativeQuery(Source,"
			SELECT
			Date,
			ID_Store,
			ID_Product,
			ID_Affected_collection,
			ID_Sales_channel,
			ID_Comparable_flag,
			GMV_excl_VAT_local,
			GMV_excl_VAT_euro,
			Sales_PP_excl_VAT_local,
			Sales_PP_excl_VAT_euro,
			Sales_ISP_excl_VAT_local,
			Sales_ISP_excl_VAT_euro,
			Sales_FISC_excl_VAT_local,
			Sales_FISC_excl_VAT_euro,
			Sold_quantity
			FROM `expo_self_bi_sales.sales_refco` 
			        where 
			   date >=date('" & DateTime.ToText(RangeStart, [Format="yyyy-MM-dd"]) &"')
			    and    date  < date('" & DateTime.ToText(RangeEnd, [Format="yyyy-MM-dd"]) &"')
			    order by ID_Product
			    ", null, [EnableFolding=true])
			in
			    Query
			```

