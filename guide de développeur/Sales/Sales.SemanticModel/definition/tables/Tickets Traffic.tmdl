	partition 'Tickets Traffic' = m
		mode: import
		queryGroup: '02.Facts'
		source = ```
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject=P_Billing_Project]){[Name=P_Project_Name]}[Data], "
				  SELECT
				    Date,
				    Id_Store,
				    ID_Comparable_flag,
				    Transactions,
				    Visitors,
				    CASE 
				        WHEN Visitors = 0 
				            OR Visitors IS NULL 
				            OR Transactions = 0 
				            OR Transactions IS NULL 
				        THEN 'N' 
				        ELSE 'O' 
				    END AS significatif_rate
				FROM 
				    `expo_self_bi_sales.visitors`
				WHERE 
				    Date >= DATE_TRUNC(
				        DATE_SUB(CURRENT_DATE(), INTERVAL 36 MONTH), 
				        MONTH
				    )
				    AND Date <= CURRENT_DATE() - 1
				    ", null, [EnableFolding=true])
				in
				    Source
				```

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

