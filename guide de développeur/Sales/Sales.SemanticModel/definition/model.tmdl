model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup '01.Dimensions'

	annotation PBI_QueryGroupOrder = 0

queryGroup '02.Facts'

	annotation PBI_QueryGroupOrder = 1

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Goal","Sales","Product","Store","Affected Collection","Channel","Calendar","RangeEnd","RangeStart","_KPI","Sales Class Level","Product Hierarchy","Comparable Flag","Tickets Traffic","Local Currency","P_Billing_Project","P_Project_Name"]

annotation __BNorm = 1

annotation __TEdtr = 1

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

annotation TranslationsBuilder = Version:2.2-Updated:2026-06-13

ref table Product
ref table Store
ref table 'Affected Collection'
ref table Channel
ref table Calendar
ref table _KPI
ref table 'Product Hierarchy'
ref table 'Comparable Flag'
ref table Goal
ref table 'Tickets Traffic'
ref table 'Local Currency'
ref table Sales
ref table 'Sales Class Level'

ref cultureInfo en-US
ref cultureInfo fr-FR

